{
  "name": "@relayerjs/nestjs",
  "version": "0.0.0",
  "description": "NestJS integration for Relayer — DI-native CRUD services and controllers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awHamer/relayer",
    "directory": "packages/nestjs"
  },
  "keywords": [
    "nestjs",
    "crud",
    "drizzle",
    "orm",
    "relayer",
    "typescript",
    "rest-api"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@relayerjs/core": "workspace:*",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@relayerjs/drizzle": "workspace:^",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "reflect-metadata": ">=0.1.13",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/testing": "^11.1.3",
    "@relayerjs/drizzle": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "vitest": "^3.2.1"
  }
}
