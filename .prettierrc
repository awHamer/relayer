{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "printWidth": 100,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": ["<BUILTIN_MODULES>", "<THIRD_PARTY_MODULES>", "^@relayerjs/(.*)$", "", "^[./]"],
  "importOrderParserPlugins": ["typescript", "decorators-legacy", "jsx"]
}
